{
  "name": "@speakai/mcp-server",
  "version": "1.4.0",
  "mcpName": "io.github.speakai/mcp-server",
  "description": "Official Speak AI MCP Server — connect Claude and other AI assistants to Speak AI's transcription, insights, and media management API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "speakai-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && cp src/types.d.ts dist/index.d.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "speak-ai",
    "transcription",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "author": "Speak AI",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "chalk-template": "^1.1.2",
    "commander": "^14.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@speakai/shared": "^1.6.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  }
}
